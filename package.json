{
  "name": "sanctum",
  "version": "0.1.0",
  "private": true,
  "description": "Sanctum monorepo — a fully-offline, long-context private records analyst built on the QVAC SDK. Tether QVAC 'Unleash Edge AI' hackathon (Track: General Purpose). Workspaces: apps/server (on-device inference server) + apps/mobile (Expo app).",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.17"
  },
  "workspaces": [
    "apps/server",
    "apps/mobile"
  ],
  "scripts": {
    "serve": "npm run serve --workspace @sanctum/server",
    "start": "concurrently --kill-others-on-fail -n server,mobile -c blue,magenta \"npm run serve\" \"npm run mobile\"",
    "smoke": "npm run smoke --workspace @sanctum/server",
    "ask": "npm run ask --workspace @sanctum/server --",
    "doctor": "npm run doctor --workspace @sanctum/server",
    "models": "npm run models --workspace @sanctum/server",
    "mobile": "npm run start --workspace @sanctum/mobile",
    "mobile:android": "npm run android --workspace @sanctum/mobile",
    "mobile:ios": "npm run ios --workspace @sanctum/mobile",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:up:web": "docker compose --profile websearch up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
