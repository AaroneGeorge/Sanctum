{
  "$schema": "https://json.schemastore.org/tsconfig",
  "//": "Shared TypeScript options for the monorepo. apps/server extends this; apps/mobile uses expo/tsconfig.base.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "noEmit": true
  }
}
