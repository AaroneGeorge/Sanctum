# ── Dependencies (hoisted to repo-root node_modules + any per-workspace copies) ──
node_modules/

# ── Env / secrets (any workspace; .env.example stays tracked) ──
.env
.env*.local

# ── Model weights are large; fetch via apps/server/scripts/download-models.sh (never commit GGUFs).
**/models/*.gguf
# Keep the checksum manifest committed for reproducibility:
!**/models/SHA256SUMS.txt

# ── Generated run artifacts (the committed reference copies — e.g. profiler.txt — stay tracked) ──
**/artifacts/*.jsonl
**/artifacts/profiler.json

# ── Expo / React Native ──
**/.expo/
**/dist/
**/web-build/
expo-env.d.ts
*.tsbuildinfo

# ── Misc ──
*.log
.DS_Store
