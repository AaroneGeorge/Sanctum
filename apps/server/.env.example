# Sanctum server — OPTIONAL web-augmented mode (POST /ask/web).
#
# Leave everything here UNSET to stay 100% offline: with no key/endpoint configured, the web mode
# auto-degrades to an on-device-only answer and the server makes ZERO external calls.
#
# These vars are read by src/search.ts. The `npm run serve` script does NOT auto-load this file, so
# set them inline (e.g. `SEARCH_API_KEY=tvly-… npm run serve`) or export them into your shell
# (`set -a; source .env; set +a`).

# Which provider handles the DE-IDENTIFIED medical search queries.  tavily (default) | brave | searxng
SEARCH_PROVIDER=tavily

# API key for Tavily or Brave (NOT needed for searxng). Free Tavily key: https://app.tavily.com
SEARCH_API_KEY=

# Base URL of a self-hosted SearXNG instance — required ONLY when SEARCH_PROVIDER=searxng.
# With SearXNG you run the search yourself, so not even the de-identified queries reach a third party.
SEARCH_ENDPOINT=

# Per-request web-search timeout in milliseconds (default 6000).
SEARCH_TIMEOUT_MS=6000
