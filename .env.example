# Root .env — read by `docker compose` for variable substitution in docker-compose.yml.
# (App-level config lives in apps/server/.env and apps/mobile/.env — see their own .env.example files.)
#
# Copy to .env and edit:  cp .env.example .env

# Which on-device model the server loads.  medpsy-1.7b (default) | medpsy-4b
SANCTUM_MODEL=medpsy-1.7b

# Inference device.  cpu (default, portable) | gpu (advanced; needs Vulkan passthrough — see README)
QVAC_DEVICE=cpu
QVAC_GPU_LAYERS=0

# Context window in tokens. Raise for long-context demos if RAM/VRAM allows.
QVAC_CTX=8192
